---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Terms of Use — Labrats" description="Terms of Use for Labrats by The Metavision." canonical="/terms">
  <Navbar />
  <main class="page">

    <section class="page-hero">
      <div class="container page-hero__content">
        <h1 class="page-hero__title">Terms of Use</h1>
        <p class="page-hero__meta">Last updated: April 2026</p>
      </div>
    </section>

    <section class="legal-content">
      <div class="container">
        <div class="legal-body">

          <p class="legal-notice">Our Terms of Use are currently being updated. The full terms governing your use of this website and our content will be published here shortly. Thank you for your patience.</p>

          <h2>Acceptance of Terms</h2>
          <p>By accessing or using the Labrats website, you agree to be bound by these Terms of Use and all applicable laws and regulations. If you do not agree with any of these terms, you are not permitted to use this site.</p>

          <h2>Intellectual Property</h2>
          <p>All content on this website — including text, images, characters, illustrations, and branding — is the property of The Metavision Multimedia Limited and is protected by applicable copyright and intellectual property laws. You may not reproduce, distribute, or create derivative works without express written permission.</p>

          <h2>Use of the Site</h2>
          <p>This website is provided for informational and promotional purposes only. You agree not to use the site for any unlawful purpose, to transmit harmful content, or to attempt to gain unauthorised access to any part of our systems.</p>

          <h2>Disclaimer</h2>
          <p>This website and its content are provided on an "as is" basis. The Metavision Multimedia Limited makes no warranties, expressed or implied, regarding the accuracy, completeness, or availability of the site or its content.</p>

          <h2>Limitation of Liability</h2>
          <p>To the fullest extent permitted by law, The Metavision Multimedia Limited shall not be liable for any indirect, incidental, or consequential damages arising from your use of this website or its content.</p>

          <h2>Changes to These Terms</h2>
          <p>We reserve the right to update or amend these Terms of Use at any time. Continued use of the website following any changes constitutes your acceptance of the revised terms.</p>

          <h2>Contact Us</h2>
          <p>For queries about these Terms of Use, please contact us at <a href="mailto:squeak@labrats.uk" class="legal-link">squeak@labrats.uk</a>.</p>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .page {
    padding-top: 80px;
    background: var(--color-white);
    min-height: 100vh;
  }

  .page-hero {
    padding: 64px 0 48px;
    background: var(--color-white);
    border-bottom: 2px solid var(--color-teal);
  }

  .page-hero__content {
    max-width: 760px;
  }

  .page-hero__title {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 72px);
    color: var(--color-black);
    line-height: 1;
    margin-bottom: 12px;
  }

  .page-hero__meta {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
    color: color-mix(in srgb, var(--color-black) 50%, transparent);
    text-transform: uppercase;
  }

  .legal-content {
    padding: 64px 0 120px;
    background: var(--color-white);
  }

  .legal-body {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .legal-notice {
    background: color-mix(in srgb, var(--color-teal) 10%, var(--color-white));
    border-left: 4px solid var(--color-teal);
    padding: 16px 20px;
    border-radius: 0 var(--radius) var(--radius) 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-black);
    font-style: italic;
  }

  .legal-body h2 {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-black);
    margin-top: 8px;
    margin-bottom: 0;
  }

  .legal-body p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-black);
    margin: 0;
  }

  .legal-link {
    color: var(--color-teal);
    font-weight: 600;
    transition: color 0.2s;
  }

  .legal-link:hover {
    color: var(--color-black);
  }
</style>
