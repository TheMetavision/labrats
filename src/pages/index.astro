---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import BookSeries from '../components/BookSeries.astro';
import RatPack from '../components/RatPack.astro';
import MerchTeaser from '../components/MerchTeaser.astro';
import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TVSeries",
  "name": "Labrats",
  "description": "An animated sci-fi series about genetically enhanced lab rats fighting for freedom against their creators.",
  "genre": ["Animation", "Science Fiction", "Action"],
  "creator": {
    "@type": "Organization",
    "name": "The Metavision Multimedia Limited",
    "url": "https://themetavision.co.uk"
  }
};
---

<Layout canonical="/" jsonLd={jsonLd}>
  <Navbar />
  <main>
    <Hero />
    <BookSeries />
    <RatPack />
    <MerchTeaser />
    <Newsletter />
  </main>
  <Footer />
</Layout>
