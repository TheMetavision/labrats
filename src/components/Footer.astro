---

<footer class="footer">
  <div class="footer__top-border"></div>
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Labrats Home">
        <img
          src="https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=1440,h=756,fit=crop,f=jpeg/Aq2q3anW6qTLnbeK/labrats-landscape-jul25-YZ9jxZw971UBgjew.png"
          alt="Labrats logo"
          class="footer__logo-img"
        />
      </a>
      <p class="footer__tagline">
        Join the rebellion.<br />Unleash the mischief.
      </p>
    </div>

    <nav class="footer__nav" aria-label="Explore navigation">
      <h3 class="footer__nav-title">Explore</h3>
      <ul class="footer__links">
        {exploreLinks.map(link => (
          <li>
            <a href={link.href} class="footer__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <nav class="footer__nav" aria-label="Legal navigation">
      <h3 class="footer__nav-title">Legal</h3>
      <ul class="footer__links">
        {legalLinks.map(link => (
          <li>
            <a href={link.href} class="footer__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="footer__connect">
      <h3 class="footer__nav-title">Connect</h3>
      <div class="footer__social-row">
        {socials.map(s => (
          <a
            href={s.href}
            class="footer__social-icon"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.label}
            set:html={s.svg}
          />
        ))}
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">&copy; Labrats 2026. Part of <a href="https://www.themetavision.co.uk" target="_blank" rel="noopener noreferrer" class="footer__copy-link">The Metavision IP Universe</a>. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-black);
  }

  .footer__top-border {
    height: 3px;
    background: linear-gradient(90deg, var(--color-teal), var(--color-yellow), var(--color-teal));
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto auto auto;
    gap: 64px;
    padding-top: 60px;
    padding-bottom: 72px;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer__logo-img {
    height: 80px;
    width: auto;
    border-radius: 6px;
    transition: opacity 0.2s;
  }

  .footer__logo-img:hover {
    opacity: 0.85;
  }

  .footer__tagline {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-white);
    font-style: italic;
  }

  .footer__nav-title {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-yellow);
    margin-bottom: 16px;
  }

  .footer__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__link {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-white);
    transition: color 0.2s;
    letter-spacing: 0.5px;
  }

  .footer__link:hover {
    color: var(--color-yellow);
  }

  .footer__connect {
    min-width: 120px;
  }

  .footer__social-row {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .footer__social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-teal);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .footer__social-icon:hover {
    color: var(--color-yellow);
    transform: translateY(-2px);
  }

  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding: 20px 0;
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__copy {
    font-size: 13px;
    color: var(--color-white);
  }

  .footer__copy-link {
    color: var(--color-black);
    background: var(--color-yellow);
    padding: 1px 6px;
    border-radius: 3px;
    text-decoration: none;
    font-weight: 700;
    transition: background var(--transition), color var(--transition);
  }

  .footer__copy-link:hover {
    background: var(--color-teal);
    color: var(--color-black);
  }

  @media (max-width: 768px) {
    .footer__inner {
      padding-top: 40px;
    }
  }

  @media (max-width: 900px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
