---
import { getSiteSettings, urlFor } from '../lib/sanity';

const settings = await getSiteSettings();
const currentYear = new Date().getFullYear();

const footerLogoUrl = settings?.footerLogo
  ? urlFor(settings.footerLogo).width(400).format('webp').url()
  : settings?.logo
    ? urlFor(settings.logo).width(400).format('webp').url()
    : 'https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=1440,h=756,fit=crop,f=jpeg/Aq2q3anW6qTLnbeK/labrats-landscape-jul25-YZ9jxZw971UBgjew.png';

const exploreLinks = [
  { label: 'Home', href: '/' },
  { label: 'Media', href: '/media' },
  { label: 'Merch', href: '/merch' },
  { label: 'Rat Tales', href: '/rat-tales' },
  { label: 'Meet The Rat Pack', href: '/meet-the-rat-pack' },
  { label: 'Contact', href: '/contact' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Use', href: '/terms' },
];

const socialSvgs: Record<string, string> = {
  Facebook: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  YouTube: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  TikTok: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>`,
  Instagram: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  X: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  Threads: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017C1.5 8.418 2.35 5.564 3.996 3.513 5.845 1.208 8.598.027 12.179.003h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.96-.065-1.187.408-2.26 1.33-3.02.878-.724 2.1-1.152 3.535-1.239 1.036-.063 2.003.02 2.89.247-.172-.933-.556-1.63-1.146-2.071-.668-.498-1.6-.753-2.767-.758h-.053c-.86.005-1.97.19-2.747.795l-1.158-1.652c1.1-.856 2.581-1.291 4.396-1.291h.073c3.536.035 5.55 2.074 5.933 5.065a8.85 8.85 0 0 1 2.37 1.9c.87 1.018 1.477 2.32 1.672 3.862.36 2.866-.55 5.334-2.565 6.958-1.746 1.408-4.122 2.149-7.064 2.202zM9.197 15.008c.033.606.318 1.098.802 1.383.576.34 1.348.474 2.142.435 1.074-.06 1.89-.44 2.427-1.128.378-.484.648-1.128.804-1.918-.762-.182-1.578-.262-2.436-.214-1.553.094-2.892.564-3.739 1.442z"/></svg>`,
};

const sanityLinks = settings?.socialLinks || [];
const socials = sanityLinks.length > 0 ? sanityLinks.map((link: any) => ({
  label: link.platform,
  href: link.url,
  svg: socialSvgs[link.platform] || '',
})) : [
  { label: 'Facebook', href: 'https://www.facebook.com/Labratsmm/', svg: socialSvgs.Facebook },
  { label: 'YouTube', href: 'https://www.youtube.com/@LabratsUK', svg: socialSvgs.YouTube },
  { label: 'TikTok', href: 'https://www.tiktok.com/@labrats.uk', svg: socialSvgs.TikTok },
  { label: 'Instagram', href: 'https://www.instagram.com/labrats2025', svg: socialSvgs.Instagram },
];
---

<footer class="footer">
  <div class="footer__top-border"></div>
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Labrats Home">
        <img
          src={footerLogoUrl}
          alt="Labrats logo"
          class="footer__logo-img"
        />
      </a>
      <p class="footer__tagline">
        Join the rebellion.<br />Unleash the mischief.
      </p>
    </div>

    <nav class="footer__nav" aria-label="Explore navigation">
      <h3 class="footer__nav-title">Explore</h3>
      <ul class="footer__links">
        {exploreLinks.map(link => (
          <li>
            <a href={link.href} class="footer__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <nav class="footer__nav" aria-label="Legal navigation">
      <h3 class="footer__nav-title">Legal</h3>
      <ul class="footer__links">
        {legalLinks.map(link => (
          <li>
            <a href={link.href} class="footer__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="footer__connect">
      <h3 class="footer__nav-title">Connect</h3>
      <div class="footer__social-row">
        {socials.map(s => (
          <a
            href={s.href}
            class="footer__social-icon"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.label}
            set:html={s.svg}
          />
        ))}
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">&copy; Labrats 2026. Part of <a href="https://www.themetavision.co.uk" target="_blank" rel="noopener noreferrer" class="footer__copy-link">The Metavision IP Universe</a>. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-black);
  }

  .footer__top-border {
    height: 3px;
    background: linear-gradient(90deg, var(--color-teal), var(--color-yellow), var(--color-teal));
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto auto auto;
    gap: 64px;
    padding-top: 60px;
    padding-bottom: 72px;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer__logo-img {
    height: 80px;
    width: auto;
    border-radius: 6px;
    transition: opacity 0.2s;
  }

  .footer__logo-img:hover {
    opacity: 0.85;
  }

  .footer__tagline {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-white);
    font-style: italic;
  }

  .footer__nav-title {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-yellow);
    margin-bottom: 16px;
  }

  .footer__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__link {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-white);
    transition: color 0.2s;
    letter-spacing: 0.5px;
  }

  .footer__link:hover {
    color: var(--color-yellow);
  }

  .footer__connect {
    min-width: 120px;
  }

  .footer__social-row {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .footer__social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-teal);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .footer__social-icon:hover {
    color: var(--color-yellow);
    transform: translateY(-2px);
  }

  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding: 20px 0;
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__copy {
    font-size: 13px;
    color: var(--color-white);
  }

  .footer__copy-link {
    color: var(--color-black);
    background: var(--color-yellow);
    padding: 1px 6px;
    border-radius: 3px;
    text-decoration: none;
    font-weight: 700;
    transition: background var(--transition), color var(--transition);
  }

  .footer__copy-link:hover {
    background: var(--color-teal);
    color: var(--color-black);
  }

  @media (max-width: 768px) {
    .footer__inner {
      padding-top: 40px;
    }
  }

  @media (max-width: 900px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
