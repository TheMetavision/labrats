---
---

<section class="newsletter" id="newsletter">
  <div class="container newsletter__content">
    <div class="newsletter__inner">
      <h2 class="newsletter__title">Stay Squeaky Informed</h2>
      <form
        class="newsletter__form"
        name="newsletter"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
      >
        <input type="hidden" name="form-name" value="newsletter" />
        <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>
        <div class="newsletter__input-wrap">
          <input
            type="email"
            id="email"
            name="email"
            placeholder="Enter your email address..."
            class="newsletter__input"
            required
            autocomplete="email"
          />
          <button type="submit" class="newsletter__submit">
            Subscribe
          </button>
        </div>
        <p class="newsletter__note">No spam, unsubscribe anytime. Rat's honour.</p>
      </form>
    </div>
  </div>
</section>


<style>
  .newsletter {
    background: var(--color-teal);
    padding: 64px 0;
  }

  .newsletter__content {
    display: flex;
    justify-content: center;
  }

  .newsletter__inner {
    max-width: 640px;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .newsletter__title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 900;
    color: var(--color-white);
    line-height: 1;
    text-transform: uppercase;
    margin: 0;
  }

  .newsletter__form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 100%;
  }

  .newsletter__input-wrap {
    display: flex;
    width: 100%;
    max-width: 520px;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-white) 30%, transparent);
  }

  .newsletter__input {
    flex: 1;
    background: color-mix(in srgb, var(--color-white) 20%, transparent);
    border: none;
    padding: 16px 20px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-white);
    outline: none;
    transition: background 0.2s;
  }

  .newsletter__input::placeholder {
    color: color-mix(in srgb, var(--color-white) 70%, transparent);
  }

  .newsletter__input:focus {
    background: color-mix(in srgb, var(--color-white) 28%, transparent);
  }

  .newsletter__submit {
    flex-shrink: 0;
    padding: 16px 28px;
    white-space: nowrap;
    background: var(--color-yellow);
    color: var(--color-black);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  .newsletter__submit:hover {
    background: color-mix(in srgb, var(--color-yellow) 85%, var(--color-white));
  }

  .newsletter__note {
    font-size: 13px;
    color: color-mix(in srgb, var(--color-white) 80%, transparent);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .newsletter__input-wrap {
      flex-direction: column;
      border-radius: var(--radius-lg);
      overflow: visible;
      box-shadow: none;
      gap: 8px;
    }

    .newsletter__input {
      border-radius: var(--radius);
      box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-white) 30%, transparent);
    }

    .newsletter__submit {
      border-radius: var(--radius);
      width: 100%;
    }
  }
</style>
