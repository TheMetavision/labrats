        },
        body: JSON.stringify({
          email: email,
          groups: ['184360862869358023'],
          fields: { source: 'labrats-newsletter' }
        })
      });

      if (res.ok || res.status === 200 || res.status === 201) {
        nlBtn.textContent = "You're in! Welcome to the lab.";
        (document.getElementById('nl-email') as HTMLInputElement).value = '';
        setTimeout(() => { nlBtn.textContent = originalText; nlBtn.disabled = false; }, 4000);
      } else if (res.status === 422) {
        nlBtn.textContent = "You're already in the lab!";
        (document.getElementById('nl-email') as HTMLInputElement).value = '';
        setTimeout(() => { nlBtn.textContent = originalText; nlBtn.disabled = false; }, 3000);
      } else {
        throw new Error('Subscription failed');
      }
    } catch {
      nlBtn.textContent = 'Something went wrong — try again';
      nlBtn.disabled = false;
      setTimeout(() => { nlBtn.textContent = originalText; }, 3000);
